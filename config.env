## ============================================================
## SimpleTuner 配置文件 — M4 32GB 人脸 LoRA 训练
## 用途：AI带货视频 · 人脸一致性训练
## 最后更新：2026-04-13
## ============================================================

# ------------------------------------------------------------
# 基础模型选择（二选一）
# ------------------------------------------------------------
# 方案A：Flux.1-dev（推荐，人脸还原最好，需要HuggingFace授权）
MODEL_TYPE="flux"
PRETRAINED_MODEL_NAME_OR_PATH="black-forest-labs/FLUX.1-dev"

# 方案B：SDXL（备用，无需授权，速度快）
# MODEL_TYPE="sdxl"
# PRETRAINED_MODEL_NAME_OR_PATH="stabilityai/stable-diffusion-xl-base-1.0"

# HuggingFace Token（Flux 需要，SDXL 可留空）
HUGGING_FACE_HUB_TOKEN=""

# ------------------------------------------------------------
# 输出路径
# ------------------------------------------------------------
OUTPUT_DIR="./output/face_lora"
LOGGING_DIR="./logs"
TRACKER_PROJECT_NAME="face_lora_m4"

# ------------------------------------------------------------
# 数据集路径（把客户照片放这里）
# ------------------------------------------------------------
DATALOADER_CONFIG="./multidatabackend.json"

# ------------------------------------------------------------
# 训练核心参数（M4 32GB 优化）
# ------------------------------------------------------------
# 分辨率：M4 32GB 跑 1024 无压力
RESOLUTION=1024
RESOLUTION_TYPE="pixel_area"

# 批次大小：Flux 模型在 32GB 内存下推荐用 1 以避免 OOM
TRAIN_BATCH_SIZE=1

# 梯度累积：等效 batch_size = TRAIN_BATCH_SIZE × GRADIENT_ACCUMULATION_STEPS
# 等效 batch_size = 1×4 = 4，训练更稳定
GRADIENT_ACCUMULATION_STEPS=4

# 总训练步数：人脸 LoRA 推荐 1000~2000步
# 第一次训练用 1200，后续根据效果微调
MAX_TRAIN_STEPS=1200

# 混合精度：M4 原生支持 bf16，速度提升 40%+
MIXED_PRECISION="bf16"
ALLOW_TF32=true

# ------------------------------------------------------------
# LoRA 参数
# ------------------------------------------------------------
# rank 越高越精细，但训练越慢
# 人脸推荐 16，追求极限可以用 32（M4 32GB 能跑）
LORA_RANK=16
LORA_ALPHA=16

# 只训练人脸相关的注意力层（更高效）
LORA_TARGET_MODULES="to_q,to_k,to_v,to_out.0"

# ------------------------------------------------------------
# 优化器（M4 推荐）
# ------------------------------------------------------------
OPTIMIZER="adamw_bf16"
LEARNING_RATE=8e-5
LR_SCHEDULER="cosine"
LR_WARMUP_STEPS=100

# Adam 参数
ADAM_BETA1=0.9
ADAM_BETA2=0.999
ADAM_WEIGHT_DECAY=1e-2
ADAM_EPSILON=1e-8

# ------------------------------------------------------------
# 速度优化（M4 专用）
# ------------------------------------------------------------
# 数据加载并行数：M4 多核可以开4，M1 超过2会崩
DATALOADER_NUM_WORKERS=4

# 梯度检查点：节省显存（虽然 M4 不太需要，但保险开着）
GRADIENT_CHECKPOINTING=true

# 缓存 VAE 编码结果（加速，第一次跑完后重复利用）
CACHE_LATENTS=true
CACHE_LATENTS_TO_DISK=true

# Flux 专用：T5 文本编码器缓存
CACHE_TEXT_ENCODER_OUTPUTS=true
CACHE_TEXT_ENCODER_OUTPUTS_TO_DISK=true

# ------------------------------------------------------------
# 保存策略
# ------------------------------------------------------------
# 每 200 步保存一次 checkpoint（方便对比效果）
CHECKPOINTING_STEPS=200
CHECKPOINTS_TOTAL_LIMIT=5

# 最终 LoRA 格式
SAVE_LORA=true

# ------------------------------------------------------------
# 验证（训练中途自动生成对比图）
# ------------------------------------------------------------
VALIDATION_STEPS=200
# 修改为实际触发词
VALIDATION_PROMPT="a photo of ohwx person, standing in a warehouse, realistic"
VALIDATION_NEGATIVE_PROMPT="blurry, deformed, ugly, low quality"
VALIDATION_NUM_INFERENCE_STEPS=20

# ------------------------------------------------------------
# 随机种子（固定可复现）
# ------------------------------------------------------------
SEED=42

# ------------------------------------------------------------
# M4 Metal 加速（不需要 CUDA，自动使用 MPS）
# ------------------------------------------------------------
# 注意：SimpleTuner 会自动检测 MPS，无需手动设置
# 如果报错加上：PYTORCH_ENABLE_MPS_FALLBACK=1
